---
import SiteLayout from "../layouts/SiteLayout.astro";
import releases from "../data/releases.json";

const releaseList = [...releases].sort(
  (left, right) => Date.parse(right.publishedAt) - Date.parse(left.publishedAt),
);
---

<SiteLayout
  title="Updates | GSHS.app"
  description="GSHS.app 운영 배포 릴리스와 변경 기록을 확인하는 공개 페이지"
  current="updates"
>
  <section class="hero">
    <span class="eyebrow">Updates</span>
    <h1>운영 배포 릴리스 기록</h1>
    <p>
      운영 서버에 실제로 반영된 배포 이력을 기준으로 공개 릴리스를 정리합니다. 테스트 서버용
      임시 배포가 아니라 production 승격 기준의 기록만 표시합니다.
    </p>
  </section>

  {
    releaseList.length === 0 ? (
      <section class="empty-card">
        <h2>아직 공개된 릴리스가 없습니다.</h2>
        <p>다음 운영 배포가 성공하면 이 페이지에 자동으로 기록이 생성됩니다.</p>
      </section>
    ) : (
      <div class="release-list">
        {releaseList.map((release) => (
          <section class="release-card">
            <h2>{release.title}</h2>
            <p class="release-meta">
              태그 {release.tagName} · {new Date(release.publishedAt).toLocaleString("ko-KR", {
                dateStyle: "medium",
                timeStyle: "short",
                timeZone: "Asia/Seoul",
              })}
            </p>
            <p>{release.summary}</p>
            <div class="release-actions">
              <a class="cta" href={`/releases/${release.tagName}/`}>상세 보기</a>
              <a class="cta secondary" href={release.htmlUrl}>GitHub 릴리스 열기</a>
            </div>
          </section>
        ))}
      </div>
    )
  }
</SiteLayout>
